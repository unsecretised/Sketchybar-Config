#!/usr/bin/env bash

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"

#######################################
#  Monolith Circuit – Dark Tech Theme #
#######################################
# Vibe: matte charcoal, cyan/amber wiring,
# slightly denser, more “dashboardy”.

# Base colors (matte, neutral)
BASE_0="0x050608"  # Almost black
BASE_1="0x0b0d10"  # Dark base
BASE_2="0x13161c"  # Charcoal
BASE_3="0x1b2028"  # Panel
BASE_4="0x252c36"  # Raised panel

# Accents
ACCENT_CYAN="0x5ad1e8"     # primary
ACCENT_AMBER="0xe0a96b"    # highlight
ACCENT_LIME="0xa6da95"     # OK status
ACCENT_CRIMSON="0xf7768e"  # warnings
ACCENT_VIOLET="0x9b7fdb"   # secondary
ACCENT_STEEL="0x7f849c"    # muted lines

# Text
FG_PRIMARY="0xe2e8f0"
FG_SECONDARY="0xcbd5f5"
FG_DIM="0x7f849c"

##############################
#  Bar – matte monolith top  #
##############################

sketchybar --bar position=top \
                height=32 \
                color=0xff${BASE_1:2} \
                shadow=on \
                sticky=on \
                padding_left=6 \
                padding_right=6 \
                corner_radius=0 \
                border_width=2 \
                border_color=0xff${BASE_3:2}

################################
#  Global defaults / “modules” #
################################

MODULE_BG_ALPHA="16"       # very subtle background
MODULE_BORDER_ALPHA="45"   # thin edge
TEXT_ALPHA="ff"

default=(
  padding_left=6
  padding_right=6

  icon.font="JetBrainsMono Nerd Font:Bold:16.0"
  label.font="JetBrainsMono Nerd Font:Medium:13.0"

  icon.font.size=15.0
  label.font.size=13.0

  icon.color=0x${TEXT_ALPHA}${ACCENT_CYAN:2}
  label.color=0x${TEXT_ALPHA}${FG_PRIMARY:2}

  icon.padding_left=6
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=6

  background.color=0x${MODULE_BG_ALPHA}${BASE_3:2}
  background.corner_radius=7
  background.height=24
  background.border_width=1
  background.border_color=0x${MODULE_BORDER_ALPHA}${BASE_4:2}
)

sketchybar --default "${default[@]}"

################################
#  LEFT RAIL: logo + workspaces
################################

# Left vertical "rail" feel: Apple + a tiny status LED
sketchybar --add item applelogo left \
           --set applelogo icon= \
                          icon.font="JetBrainsMono Nerd Font:Bold:14.0" \
                          icon.color=0xff${ACCENT_AMBER:2} \
                          background.color=0x22${BASE_3:2} \
                          background.corner_radius=999 \
                          background.border_width=0 \
                          background.border_color=0x70${ACCENT_AMBER:2} \
                          label.drawing=off \
			  icon.padding_left=5 \
			  icon.padding_right=5

# Small separator LED
sketchybar --add item rail_dot left \
           --set rail_dot icon= \
                          icon.color=0xaa${ACCENT_STEEL:2} \
                          background.drawing=off \
                          label.drawing=off \
                          icon.padding_left=2 \
                          icon.padding_right=2

############################
#  Rift Workspaces (CORE)  #
############################
# Functionality preserved: same RIFT_DATA, loop, updater
# Only styling / icons changed.

SPACE_ICONS=("◈" "◆" "◇" "⬢" "⬡" "⬣" "⬟" "◍" "◌" "◎")
SPACE_COLORS=(
  "${ACCENT_CYAN:2}"   "${ACCENT_VIOLET:2}" "${ACCENT_AMBER:2}" "${ACCENT_LIME:2}" "${ACCENT_CYAN:2}"
  "${ACCENT_VIOLET:2}" "${ACCENT_AMBER:2}"  "${ACCENT_LIME:2}"  "${ACCENT_CYAN:2}" "${ACCENT_VIOLET:2}"
)

RIFT_DATA="$(rift-cli query workspaces 2>/dev/null || echo '[]')"
workspace_count=$(printf '%s\n' "$RIFT_DATA" | jq 'length')
max_spaces=${#SPACE_ICONS[@]}
(( workspace_count > max_spaces )) && workspace_count=$max_spaces

for (( i=0; i<workspace_count; i++ )); do
  sid=$((i + 1))
  color_index=$((i % ${#SPACE_COLORS[@]}))
  space_color="${SPACE_COLORS[color_index]}"

  space=(
    icon="${SPACE_ICONS[i]}"
    icon.color=0xff$space_color
    icon.highlight_color=0xff${FG_PRIMARY:2}
    icon.padding_left=6
    icon.padding_right=3

    background.color=0x20${BASE_2:2}
    background.corner_radius=9
    background.border_width=0
    background.border_color=0x90$space_color
    background.height=22

    label.drawing=on
    label.color=0xff${FG_SECONDARY:2}
    label.font="JetBrainsMono Nerd Font:Medium:13.0"
    label.padding_left=4
    label.padding_right=4
  )

  sketchybar --add item "rift_space.$sid" left \
             --set "rift_space.$sid" "${space[@]}"
done

# Updater stays as-is logically (hidden)
sketchybar --add item rift_updater left \
           --set rift_updater script="$PLUGIN_DIR/rift_workspaces.sh" \
                              update_freq=3 \
                              drawing=off

################################
#  LEFT MID: front app + BT    #
################################

# Front App – cyan border, name only
sketchybar --add item front_app left \
           --set front_app icon.drawing=off \
                          background.color=0x22${BASE_3:2} \
                          background.corner_radius=8 \
                          background.border_width=1 \
                          background.border_color=0xa0${ACCENT_CYAN:2} \
                          label.color=0xff${FG_PRIMARY:2} \
                          label.font="JetBrainsMono Nerd Font:Medium:13.0" \
                          label.padding_left=8 \
                          label.padding_right=10 \
                          script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

sketchybar --add item launcher left \
           --set launcher icon= \
                         icon.color=0xff${ACCENT_AMBER:2} \
                         label="Launch" \
			 label.drawing=off \
                         label.color=0xff${FG_PRIMARY:2} \
                         background.color=0x20${BASE_3:2} \
                         background.corner_radius=8 \
                         background.border_width=1 \
                         background.border_color=0x80${ACCENT_AMBER:2} \
                         click_script='sketchybar --set $NAME popup.drawing=toggle' \
                         popup.horizontal=on \
                         popup.align=center \
                         popup.background.color=0xee${BASE_2:2} \
                         popup.background.corner_radius=10 \
                         popup.background.border_width=1 \
                         popup.background.border_color=0xa0${BASE_4:2}

sketchybar --add item launch.finder popup.launcher \
           --set launch.finder icon=\
                               label="Finder" \
			       label.drawing=off \
                               icon.color=0xff${ACCENT_CYAN:2} \
                               background.color=0x22${BASE_3:2} \
                               background.corner_radius=7 \
                               background.border_width=1 \
                               background.border_color=0x60${ACCENT_CYAN:2} \
                               click_script='open -a Finder'

sketchybar --add item launch.ghostty popup.launcher \
           --set launch.ghostty icon=󱙝\
                               label="Ghostty" \
			       label.drawing=off \
                               icon.color=0xff${ACCENT_CYAN:2} \
                               background.color=0x22${BASE_3:2} \
                               background.corner_radius=7 \
                               background.border_width=1 \
                               background.border_color=0x60${ACCENT_CYAN:2} \
                               click_script='open -a /Applications/Ghostty.app'

sketchybar --add item launch.firefox popup.launcher \
           --set launch.firefox icon= \
                                label="Firefox" \
                                icon.color=0xff${ACCENT_CYAN:2} \
			       label.drawing=off \
                                background.color=0x22${BASE_3:2} \
                                background.corner_radius=7 \
                                background.border_width=1 \
                                background.border_color=0x60${ACCENT_CYAN:2} \
                                click_script='open -a "Firefox"'

# Spotify
sketchybar --add item launch.spotify popup.launcher \
           --set launch.spotify icon= \
                                label="Spotify" \
                                icon.color=0xff${ACCENT_CYAN:2} \
                                background.color=0x22${BASE_3:2} \
			       label.drawing=off \
                                background.corner_radius=7 \
                                background.border_width=1 \
                                background.border_color=0x60${ACCENT_CYAN:2} \
                                click_script='open -a "Spotify"'

# Discord
sketchybar --add item launch.discord popup.launcher \
           --set launch.discord icon= \
                                label="Discord" \
                                icon.color=0xff${ACCENT_CYAN:2} \
			       label.drawing=off \
                                background.color=0x22${BASE_3:2} \
                                background.corner_radius=7 \
                                background.border_width=1 \
                                background.border_color=0x60${ACCENT_CYAN:2} \
                                click_script='open -a "Discord"'

# Bluetooth – small module
sketchybar --add item bluetooth left \
           --set bluetooth icon=󰂯 \
                          icon.color=0xff${ACCENT_VIOLET:2} \
                          background.color=0x18${BASE_2:2} \
                          background.corner_radius=7 \
                          background.border_width=1 \
                          background.border_color=0x70${ACCENT_VIOLET:2} \
                          label.drawing=off \
                          update_freq=5 \
                          script="$PLUGIN_DIR/bluetooth.sh" \
           --subscribe bluetooth mouse.clicked

# Clock – final anchor on far right
sketchybar --add item clock right \
           --set clock icon=󰥔 \
                      icon.color=0xff${ACCENT_CYAN:2} \
                      label.color=0xff${FG_PRIMARY:2} \
                      background.color=0x22${BASE_3:2} \
                      background.corner_radius=8 \
                      background.border_width=1 \
                      background.border_color=0xa0${ACCENT_CYAN:2} \
                      label.padding_left=6 \
                      label.padding_right=10 \
                      update_freq=1 \
                      script="$PLUGIN_DIR/clock.sh"
# Battery – color-coded in script, but base teal
sketchybar --add item battery right \
           --set battery icon=󰁹 \
                        icon.color=0xff${ACCENT_LIME:2} \
                        label.color=0xff${FG_SECONDARY:2} \
                        background.color=0x18${BASE_3:2} \
                        background.corner_radius=7 \
                        background.border_width=1 \
                        background.border_color=0x70${ACCENT_LIME:2} \
                        update_freq=60 \
                        script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

# Volume
sketchybar --add item volume right \
           --set volume icon=󰕾 \
                       icon.color=0xff${ACCENT_AMBER:2} \
                       label.color=0xff${FG_SECONDARY:2} \
                       background.color=0x18${BASE_3:2} \
                       background.corner_radius=7 \
                       background.border_width=1 \
                       background.border_color=0x70${ACCENT_AMBER:2} \
                       script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change


#######################################
#  RIGHT: Spotify popup (refined)     #
#######################################

SPOTIFY_EVENT="com.spotify.client.PlaybackStateChanged"
POPUP_SCRIPT="sketchybar -m --set \$NAME popup.drawing=toggle"

# Compact “Now Playing” tile
sketchybar --add event spotify_change $SPOTIFY_EVENT \
           --add item spotify.name right \
           --set spotify.name icon=󰓇 \
                             label="Now Playing" \
                             label.color=0xff${FG_PRIMARY:2} \
                             label.font="JetBrainsMono Nerd Font:Medium:13.0" \
                             background.color=0x26${BASE_3:2} \
                             background.corner_radius=9 \
                             background.border_width=1 \
                             background.border_color=0xa0${ACCENT_TEAL:2} \
                             padding_left=9 \
                             padding_right=9 \
                             click_script="$POPUP_SCRIPT" \
                             popup.horizontal=on \
                             popup.align=center \
                             popup.background.color=0xee${BASE_2:2} \
                             popup.background.corner_radius=11 \
                             popup.background.border_width=1 \
                             popup.background.border_color=0xa0${BASE_4:2}

SPOTIFY_POPUP_BG="0x22${BASE_3:2}"
SPOTIFY_POPUP_RADIUS=7

# Back
sketchybar --add item spotify.back popup.spotify.name \
           --set spotify.back icon=󰒮 \
                             icon.color=0xff${ACCENT_CYAN:2} \
                             icon.highlight_color=0xff${ACCENT_LIME:2} \
                             background.color=$SPOTIFY_POPUP_BG \
                             background.corner_radius=$SPOTIFY_POPUP_RADIUS \
                             background.border_width=1 \
                             background.border_color=0x70${ACCENT_CYAN:2} \
                             label.drawing=off \
                             script="$PLUGIN_DIR/spotify.sh" \
           --subscribe spotify.back mouse.clicked

# Play / pause
sketchybar --add item spotify.play popup.spotify.name \
           --set spotify.play icon=󰐊 \
                             icon.color=0xff${ACCENT_LIME:2} \
                             icon.highlight_color=0xff${ACCENT_AMBER:2} \
                             background.color=$SPOTIFY_POPUP_BG \
                             background.corner_radius=$SPOTIFY_POPUP_RADIUS \
                             background.border_width=1 \
                             background.border_color=0x80${ACCENT_LIME:2} \
                             label.drawing=off \
                             updates=on \
                             script="$PLUGIN_DIR/spotify.sh" \
           --subscribe spotify.play mouse.clicked spotify_change

# Next
sketchybar --add item spotify.next popup.spotify.name \
           --set spotify.next icon=󰒭 \
                             icon.color=0xff${ACCENT_CYAN:2} \
                             icon.highlight_color=0xff${ACCENT_LIME:2} \
                             background.color=$SPOTIFY_POPUP_BG \
                             background.corner_radius=$SPOTIFY_POPUP_RADIUS \
                             background.border_width=1 \
                             background.border_color=0x70${ACCENT_CYAN:2} \
                             label.drawing=off \
                             script="$PLUGIN_DIR/spotify.sh" \
           --subscribe spotify.next mouse.clicked

# Shuffle
sketchybar --add item spotify.shuffle popup.spotify.name \
           --set spotify.shuffle icon=󰒝 \
                               icon.color=0xff${ACCENT_VIOLET:2} \
                               icon.highlight_color=0xff${ACCENT_LIME:2} \
                               background.color=$SPOTIFY_POPUP_BG \
                               background.corner_radius=$SPOTIFY_POPUP_RADIUS \
                               background.border_width=1 \
                               background.border_color=0x80${ACCENT_VIOLET:2} \
                               label.drawing=off \
                               script="$PLUGIN_DIR/spotify.sh" \
           --subscribe spotify.shuffle mouse.clicked

# Repeat
sketchybar --add item spotify.repeat popup.spotify.name \
           --set spotify.repeat icon=󰑖 \
                              icon.color=0xff${ACCENT_BLUE:2} \
                              icon.highlight_color=0xff${ACCENT_AMBER:2} \
                              background.color=$SPOTIFY_POPUP_BG \
                              background.corner_radius=$SPOTIFY_POPUP_RADIUS \
                              background.border_width=1 \
                              background.border_color=0x80${ACCENT_BLUE:2} \
                              label.drawing=off \
                              script="$PLUGIN_DIR/spotify.sh" \
           --subscribe spotify.repeat mouse.clicked

#################
#  Final update #
#################

echo "Monolith Circuit theme loaded."
sketchybar --update
