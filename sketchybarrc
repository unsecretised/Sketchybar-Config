#!/usr/bin/env bash

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"

#########################################
#  KANAGAWA WAVE – Muted Elegance Theme #
#########################################
# Inspired by Kanagawa & Catppuccin
# Soft, earthy tones with subtle accents

# Base colors (Kanagawa-inspired)
BG_BASE="0x1f1f28"        # Deep background
BG_SURFACE="0x2a2a37"     # Surface layer
BG_OVERLAY="0x363646"     # Overlay/highlight

# Muted accent colors
WAVE_BLUE="0x7e9cd8"      # Soft wave blue
SPRING_VIOLET="0x957fb8"  # Gentle violet
AUTUMN_RED="0xc34043"     # Muted red
WAVE_AQUA="0x7fb4ca"      # Calm aqua
SPRING_GREEN="0x98bb6c"   # Soft green
AUTUMN_YELLOW="0xdca561"  # Warm yellow
SAKURA_PINK="0xd27e99"    # Gentle pink
OLD_WHITE="0xdcd7ba"      # Aged white

# Text colors
FG_PRIMARY="0xdcd7ba"     # Main text
FG_SECONDARY="0xc8c093"   # Secondary text
FG_DIM="0x727169"         # Dimmed text

##############################
#  Bar – Transparent         #
##############################

sketchybar --bar position=top \
                height=40 \
                color=0x00000000 \
                shadow=off \
                sticky=on \
                padding_left=10 \
                padding_right=10 \
                corner_radius=0 \
                border_width=0 \
                blur_radius=0 \
                y_offset=2

################################
#  Global defaults             #
################################

MODULE_BG_ALPHA="d0"       # More opaque for visibility
MODULE_BORDER_ALPHA="40"   # Subtle borders

default=(
  padding_left=8
  padding_right=8

  icon.font="JetBrainsMono Nerd Font:Bold:16.0"
  label.font="JetBrainsMono Nerd Font:Medium:13.0"

  icon.font.size=16.0
  label.font.size=13.0

  icon.color=0xff${WAVE_BLUE:2}
  label.color=0xff${FG_PRIMARY:2}

  icon.padding_left=8
  icon.padding_right=6
  label.padding_left=6
  label.padding_right=8

  background.color=0x${MODULE_BG_ALPHA}${BG_SURFACE:2}
  background.corner_radius=10
  background.height=28
  background.border_width=1
  background.border_color=0x${MODULE_BORDER_ALPHA}${WAVE_BLUE:2}
  background.shadow.drawing=off
)

sketchybar --default "${default[@]}"

################################
#  Blur Brackets               #
################################

# Left blur bracket
sketchybar --add bracket left_group '/portal/' '/cosmic_sep/' '/rift_space\..*/' '/front_app/' '/launcher/' '/launch\..*/' '/bluetooth/' \
           --set left_group background.color=0xd0${BG_BASE:2} \
                           background.corner_radius=16 \
                           background.height=34 \
                           background.border_width=1 \
                           background.border_color=0x30${WAVE_BLUE:2} \
                           blur_radius=30

# Right blur bracket  
sketchybar --add bracket right_group '/clock/' '/battery/' '/volume/' '/spotify\..*/' \
           --set right_group background.color=0xd0${BG_BASE:2} \
                            background.corner_radius=16 \
                            background.height=34 \
                            background.border_width=1 \
                            background.border_color=0x30${WAVE_BLUE:2} \
                            blur_radius=30

################################
#  LEFT: Portal + Spaces       #
################################

sketchybar --add item portal left \
           --set portal icon=󰀘 \
                        icon.font="JetBrainsMono Nerd Font:Bold:18.0" \
                        icon.color=0xff${SAKURA_PINK:2} \
                        background.color=0x00000000 \
                        background.corner_radius=0 \
                        background.border_width=0 \
                        background.shadow.drawing=off \
                        label.drawing=off \
                        icon.padding_left=10 \
                        icon.padding_right=10 \
                        padding_left=4

sketchybar --add item cosmic_sep left \
           --set cosmic_sep icon=│ \
                           icon.color=0x40${FG_DIM:2} \
                           background.drawing=off \
                           label.drawing=off \
                           icon.padding_left=4 \
                           icon.padding_right=4

############################
#  Workspaces              #
############################

SPACE_ICONS=("一" "二" "三" "四" "五" "六" "七" "八" "九" "十")
SPACE_COLORS=(
  "${WAVE_BLUE:2}"   "${SPRING_VIOLET:2}"  "${SAKURA_PINK:2}"  "${WAVE_AQUA:2}"   "${SPRING_GREEN:2}"
  "${AUTUMN_YELLOW:2}"    "${AUTUMN_RED:2}"  "${WAVE_BLUE:2}"  "${SPRING_VIOLET:2}"  "${SAKURA_PINK:2}"
)

RIFT_DATA="$(rift-cli query workspaces 2>/dev/null || echo '[]')"
workspace_count=$(printf '%s\n' "$RIFT_DATA" | jq 'length')
max_spaces=${#SPACE_ICONS[@]}
(( workspace_count > max_spaces )) && workspace_count=$max_spaces

for (( i=0; i<workspace_count; i++ )); do
  sid=$((i + 1))
  color_index=$((i % ${#SPACE_COLORS[@]}))
  space_color="${SPACE_COLORS[color_index]}"

  space=(
    icon="${SPACE_ICONS[i]}"
    icon.color=0xb0$space_color
    icon.highlight_color=0xff${FG_PRIMARY:2}
    icon.font.size=15.0
    background.color=0x00000000
    background.corner_radius=8
    background.border_width=0
    background.height=24
    background.shadow.drawing=off
    label.drawing=off
    label.color=0xff${FG_SECONDARY:2}
    label.font="JetBrainsMono Nerd Font:Medium:12.0"
    label.padding_left=4
    label.padding_right=4
  )

  sketchybar --add item "rift_space.$sid" left \
             --set "rift_space.$sid" "${space[@]}"
done

sketchybar --add item rift_updater left \
           --set rift_updater script="$PLUGIN_DIR/rift_workspaces.sh" \
                              update_freq=3 \
                              drawing=off

################################
#  LEFT: Apps & Controls       #
################################

sketchybar --add item front_app left \
           --set front_app icon.drawing=off \
                          background.color=0x00000000 \
                          background.corner_radius=0 \
                          background.border_width=0 \
                          background.shadow.drawing=off \
                          label.color=0xff${FG_PRIMARY:2} \
                          label.font="JetBrainsMono Nerd Font:SemiBold:13.0" \
                          label.padding_left=12 \
                          label.padding_right=12 \
                          script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

sketchybar --add item launcher left \
           --set launcher icon=󱓞 \
                         icon.font.size=17.0 \
                         icon.color=0xff${AUTUMN_YELLOW:2} \
                         label.drawing=off \
                         background.color=0x00000000 \
                         background.corner_radius=0 \
                         background.border_width=0 \
                         background.shadow.drawing=off \
                         click_script='sketchybar --set $NAME popup.drawing=toggle' \
                         popup.horizontal=on \
                         popup.align=center \
                         popup.background.color=0xf0${BG_SURFACE:2} \
                         popup.background.corner_radius=12 \
                         popup.background.border_width=0 \
                         popup.background.border_color=0x60${WAVE_BLUE:2} \
                         popup.background.shadow.drawing=off

launch_apps=("finder:" "ghostty:󱙝" "firefox:" "spotify:" "discord:")
app_names=("Finder" "Ghostty" "Firefox" "Spotify" "Discord")
app_colors=("${WAVE_AQUA:2}" "${SPRING_GREEN:2}" "${AUTUMN_YELLOW:2}" "${SPRING_GREEN:2}" "${SPRING_VIOLET:2}")

for i in "${!launch_apps[@]}"; do
  IFS=':' read -r app icon <<< "${launch_apps[i]}"
  name="${app_names[i]}"
  color="${app_colors[i]}"
  
  sketchybar --add item "launch.$app" popup.launcher \
             --set "launch.$app" icon="$icon" \
                                 label="$name" \
                                 label.drawing=off \
                                 icon.color=0xff$color \
                                 icon.font.size=17.0 \
                                 background.color=0x00${BG_OVERLAY:2} \
                                 background.corner_radius=8 \
                                 background.border_width=1 \
                                 background.border_color=0x30$color \
                                 background.shadow.drawing=off \
                                 click_script="open -a \"$name\""
done

sketchybar --add item bluetooth left \
           --set bluetooth icon=󰂯 \
                          icon.font.size=16.0 \
                          icon.color=0xff${SPRING_VIOLET:2} \
                          background.color=0x00000000 \
                          background.corner_radius=0 \
                          background.border_width=0 \
                          background.shadow.drawing=off \
                          label.drawing=off \
                          update_freq=5 \
                          script="$PLUGIN_DIR/bluetooth.sh" \
           --subscribe bluetooth mouse.clicked

################################
#  RIGHT: System Monitors      #
################################

sketchybar --add item clock right \
           --set clock icon=󰥔 \
                      icon.font.size=16.0 \
                      icon.color=0xff${WAVE_BLUE:2} \
                      label.color=0xff${FG_PRIMARY:2} \
                      label.font="JetBrainsMono Nerd Font:SemiBold:13.0" \
                      background.color=0x00000000 \
                      background.corner_radius=0 \
		      background.padding_left=10 \
		      background.padding_right=10 \
                      background.border_width=0 \
                      background.shadow.drawing=off \
                      label.padding_left=8 \
                      label.padding_right=12 \
                      update_freq=1 \
                      script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
           --set battery icon=󰁹 \
                        icon.font.size=16.0 \
                        icon.color=0xff${SPRING_GREEN:2} \
                        label.color=0xff${FG_SECONDARY:2} \
                        background.color=0x00000000 \
                        background.corner_radius=0 \
		        background.padding_left=10 \
		        background.padding_right=10 \
                        background.border_width=0 \
                        background.shadow.drawing=off \
                        update_freq=60 \
                        script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

sketchybar --add item volume right \
           --set volume icon=󰕾 \
                       icon.font.size=16.0 \
                       icon.color=0xff${SAKURA_PINK:2} \
                       label.color=0xff${FG_SECONDARY:2} \
                       background.color=0x00000000 \
                       background.corner_radius=0 \
                       background.border_width=0 \
		       background.padding_left=10 \
		       background.padding_right=10 \
                       background.shadow.drawing=off \
                       script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change

#######################################
#  Spotify Player                     #
#######################################

SPOTIFY_EVENT="com.spotify.client.PlaybackStateChanged"
POPUP_SCRIPT="sketchybar -m --set \$NAME popup.drawing=toggle"

sketchybar --add event spotify_change $SPOTIFY_EVENT \
           --add item spotify.name right \
           --set spotify.name icon=󰓇 \
                             icon.font.size=17.0 \
                             label="Not Playing" \
                             label.color=0xff${FG_PRIMARY:2} \
                             label.font="JetBrainsMono Nerd Font:SemiBold:13.0" \
                             icon.color=0xff${SPRING_VIOLET:2} \
                             background.color=0x00000000 \
                             background.corner_radius=0 \
                             background.border_width=0 \
                             background.shadow.drawing=off \
                             padding_left=12 \
                             padding_right=12 \
                             click_script="$POPUP_SCRIPT" \
                             popup.horizontal=on \
                             popup.align=center \
                             popup.background.color=0xf0${BG_SURFACE:2} \
                             popup.background.corner_radius=12 \
                             popup.background.border_width=1 \
                             popup.background.border_color=0x60${SPRING_VIOLET:2} \
                             popup.background.shadow.drawing=off

controls=("back:󰒮:${WAVE_AQUA:2}" "play:󰐊:${SPRING_GREEN:2}" "next:󰒭:${WAVE_AQUA:2}" "shuffle:󰒝:${SPRING_VIOLET:2}" "repeat:󰑖:${AUTUMN_YELLOW:2}")

for ctrl in "${controls[@]}"; do
  IFS=':' read -r name icon color <<< "$ctrl"
  
  sketchybar --add item "spotify.$name" popup.spotify.name \
             --set "spotify.$name" icon="$icon" \
                                   icon.font.size=17.0 \
                                   icon.color=0xff$color \
                                   icon.highlight_color=0xff${SPRING_GREEN:2} \
                                   background.color=0x50${BG_OVERLAY:2} \
                                   background.corner_radius=8 \
                                   background.border_width=1 \
                                   background.border_color=0x30$color \
                                   background.shadow.drawing=off \
                                   label.drawing=off \
                                   updates=on \
                                   script="$PLUGIN_DIR/spotify.sh" \
             --subscribe "spotify.$name" mouse.clicked spotify_change
done

#################
#  Final launch #
#################

echo "🌊 Kanagawa Wave theme loaded - muted elegance"
sketchybar --update
