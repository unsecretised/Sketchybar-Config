#!/usr/bin/env bash

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"

##############################
#  Monochrome palette        #
##############################
BG_BASE="0x1f1f28"
BG_SURFACE="0x2a2a37"
BG_OVERLAY="0x363646"

FG_PRIMARY="0xdcd7ba"
FG_SECONDARY="0xc8c093"
FG_DIM="0x727169"

sketchybar --bar position=top \
                height=36 \
                color=0x00000000 \
                shadow=off \
                sticky=on \
                padding_left=12 \
                padding_right=12 \
                corner_radius=0 \
                border_width=0 \
                blur_radius=0 \
                y_offset=0 \
                margin=0 \
                notch_width=0

default=(
  padding_left=6
  padding_right=6

  icon.font="JetBrainsMono Nerd Font:Bold:14.0"
  label.font="JetBrainsMono Nerd Font:Medium:12.0"

  icon.color=0x80${FG_DIM:2}
  label.color=0xff${FG_PRIMARY:2}

  icon.padding_left=6
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=6

  background.color=0x00000000
  background.corner_radius=8
  background.height=26
  background.border_width=0
  background.border_color=0x00000000
  background.shadow.drawing=off
)

sketchybar --default "${default[@]}"

##############################
#  LEFT: Workspaces          #
##############################

for sid in {1..10}; do
  sketchybar --add item "workspace.$sid" left \
             --set "workspace.$sid" \
               icon="$sid" \
               icon.font="JetBrainsMono Nerd Font:Bold:13.0" \
               icon.color=0x80${FG_DIM:2} \
               icon.highlight_color=0xff${FG_PRIMARY:2} \
               icon.padding_left=8 \
               icon.padding_right=2 \
               label.drawing=off \
               label.font="JetBrainsMono Nerd Font:Medium:11.0" \
               label.padding_right=6 \
               label.padding_left=2 \
               background.color=0x00000000 \
               background.corner_radius=6 \
               background.border_width=0 \
               background.border_color=0x40${FG_DIM:2} \
               background.height=22 \
               click_script="bobrwm focus-workspace $sid"
done

sketchybar --add item sep.left left \
           --set sep.left icon= \
                      icon.font="JetBrainsMono Nerd Font:Bold:16.0" \
                      icon.color=0x30${FG_DIM:2} \
                      icon.padding_left=4 \
                      icon.padding_right=4 \
                      background.drawing=off \
                      label.drawing=off

sketchybar --add item front_app left \
           --set front_app \
               icon.drawing=off \
               label.color=0xff${FG_SECONDARY:2} \
               label.font="JetBrainsMono Nerd Font:SemiBold:12.0" \
               label.padding_left=4 \
               label.padding_right=8 \
               script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

##############################
#  RIGHT: System             #
##############################

sketchybar --add item clock right \
           --set clock \
               icon=󰥔 \
               icon.font.size=14.0 \
               icon.color=0x80${FG_DIM:2} \
               label.color=0xff${FG_PRIMARY:2} \
               label.font="JetBrainsMono Nerd Font:SemiBold:12.0" \
               label.padding_right=2 \
               update_freq=1 \
               script="$PLUGIN_DIR/clock.sh"

sketchybar --add item sep.right1 right \
           --set sep.right1 icon= \
                        icon.font="JetBrainsMono Nerd Font:Bold:16.0" \
                        icon.color=0x30${FG_DIM:2} \
                        icon.padding_left=4 \
                        icon.padding_right=4 \
                        background.drawing=off \
                        label.drawing=off

sketchybar --add item battery right \
           --set battery \
               icon=󰁹 \
               icon.font.size=14.0 \
               icon.color=0x80${FG_DIM:2} \
               label.color=0xff${FG_SECONDARY:2} \
               label.font="JetBrainsMono Nerd Font:Medium:12.0" \
               label.padding_right=2 \
               update_freq=60 \
               script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

sketchybar --add item sep.right2 right \
           --set sep.right2 icon= \
                        icon.font="JetBrainsMono Nerd Font:Bold:16.0" \
                        icon.color=0x30${FG_DIM:2} \
                        icon.padding_left=4 \
                        icon.padding_right=4 \
                        background.drawing=off \
                        label.drawing=off

sketchybar --add item volume right \
           --set volume \
               icon=󰕾 \
               icon.font.size=14.0 \
               icon.color=0x80${FG_DIM:2} \
               label.color=0xff${FG_SECONDARY:2} \
               label.font="JetBrainsMono Nerd Font:Medium:12.0" \
               label.padding_right=2 \
               script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change

##############################
#  Spotify                    #
##############################

SPOTIFY_EVENT="com.spotify.client.PlaybackStateChanged"

sketchybar --add event spotify_change "$SPOTIFY_EVENT"

sketchybar --add item spotify right \
           --set spotify \
               icon= \
               icon.font.size=14.0 \
               icon.color=0x80${FG_DIM:2} \
               label.drawing=off \
               script="$PLUGIN_DIR/spotify.sh" \
               click_script="sketchybar --set spotify popup.drawing=toggle" \
               popup.horizontal=on \
               popup.align=center \
               popup.background.color=0xf0${BG_BASE:2} \
               popup.background.corner_radius=20 \
               popup.background.border_width=1 \
               popup.background.border_color=0x40${FG_DIM:2} \
               popup.background.shadow.drawing=off \
           --subscribe spotify spotify_change mouse.clicked

sketchybar --add item spotify.track popup.spotify \
           --set spotify.track \
               icon.drawing=off \
               label="Not Playing" \
               label.color=0xff${FG_PRIMARY:2} \
               label.font="JetBrainsMono Nerd Font:SemiBold:12.0" \
               label.padding_left=14 \
               label.padding_right=14 \
               background.color=0x50${BG_SURFACE:2} \
               background.corner_radius=8 \
               background.height=24

controls=("back:󰒮" "play:󰐊" "next:󰒭" "shuffle:󰒝" "repeat:󰑖")

for ctrl in "${controls[@]}"; do
  IFS=':' read -r name icon <<< "$ctrl"

  sketchybar --add item "spotify.$name" popup.spotify \
             --set "spotify.$name" \
                 icon="$icon" \
                 icon.font.size=16.0 \
                 icon.color=0xcc${FG_DIM:2} \
                 icon.highlight_color=0xff${FG_PRIMARY:2} \
                 label.drawing=off \
                 background.color=0x50${BG_SURFACE:2} \
                 background.corner_radius=8 \
                 background.border_width=1 \
                 background.border_color=0x30${FG_DIM:2} \
                 background.shadow.drawing=off \
                 script="$PLUGIN_DIR/spotify.sh" \
             --subscribe "spotify.$name" mouse.clicked spotify_change
done

##############################
#  Workspace Updater (bobrwm)#
##############################

sketchybar --add item workspaces_updater left \
           --set workspaces_updater \
               script="$PLUGIN_DIR/workspaces.sh" \
               update_freq=2 \
               drawing=off

##############################
#  Brackets for grouping     #
##############################

sketchybar --add bracket left_group \
             '/workspace\..*/' '/sep\.left/' '/front_app/' \
           --set left_group \
             background.color=0xd0${BG_BASE:2} \
             background.corner_radius=14 \
             background.height=30 \
             background.border_width=1 \
             background.border_color=0x30${FG_DIM:2} \
             background.shadow.drawing=off

sketchybar --add bracket right_group \
             '/clock/' '/sep\.right*/' '/battery/' '/volume/' '/spotify/' \
           --set right_group \
             background.color=0xd0${BG_BASE:2} \
             background.corner_radius=14 \
             background.height=30 \
             background.border_width=1 \
             background.border_color=0x30${FG_DIM:2} \
             background.shadow.drawing=off

##############################
#  Final                     #
##############################

echo "sketchybar: bobrwm config loaded"
sketchybar --update
